<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3 http://maven.apache.org/xsd/assembly-1.1.3.xsd">
    <id>bin-linux</id>
    <formats>
        <format>zip</format>
    </formats>

    <includeBaseDirectory>false</includeBaseDirectory>

    <fileSets>
        <!-- Application dependency libs -->
        <fileSet>
            <directory>${project.build.directory}/libs</directory>
            <outputDirectory>libs</outputDirectory>
            <filtered>false</filtered>
        </fileSet>

        <!-- Bundled Zulu JRE runtime (Linux x64) under runtime/ -->
        <fileSet>
            <directory>${project.build.directory}/runtime/linux-x64</directory>
            <outputDirectory>runtime</outputDirectory>
            <filtered>false</filtered>
        </fileSet>
    </fileSets>

    <files>
        <!-- Main application jar -->
        <file>
            <source>${project.build.directory}/${jarFinalName}.jar</source>
            <outputDirectory>.</outputDirectory>
            <destName>${jarFinalName}.jar</destName>
        </file>

        <!-- Linux start script -->
        <file>
            <source>src/assembly/start.sh</source>
            <outputDirectory>.</outputDirectory>
            <fileMode>0755</fileMode>
        </file>
    </files>
</assembly>
